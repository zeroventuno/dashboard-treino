# Connection string to the NEW product Supabase project, as the app_writer role
# (non-superuser → RLS enforced). See ../app-writer.sql.
#
# Local dev: direct connection is fine (port 5432):
#   postgresql://app_writer:PASSWORD@db.<project-ref>.supabase.co:5432/postgres
#
# Vercel (serverless): use the Supabase TRANSACTION POOLER (port 6543). Grab the
# pooler string from Supabase → Database → Connection pooling, then swap the role
# from `postgres` to `app_writer`:
#   postgresql://app_writer.<project-ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://app_writer:PASSWORD@HOST:5432/postgres

# Only used by the standalone local server (src/index.ts); ignored on Vercel.
PORT=8787
